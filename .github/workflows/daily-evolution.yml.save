ame: Daily Evolution

on:
  schedule:
    - cron: '0 9 * * *'
  workflow_dispatch:

jobs:
  evolve:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 9

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: 'pnpm'

      - run: pnpm install --frozen-lockfile

      - name: Self Evolution
        env:
          GROQ_API_KEY: ${{ secrets.GROQ_API_KEY }}
        run: node -e '
          const { evolveSelf } = require("./lib/agent/core.js");
          evolveSelf("Current state analysis");
        '
